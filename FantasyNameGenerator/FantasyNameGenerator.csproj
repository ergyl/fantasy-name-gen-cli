<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
  <Title>FantasyNameGenerator</Title>
  <Description>A simple fantasy name generator for various races.</Description>
  <Version>1.0.0</Version>
  <Authors>Erik Sterner Gylleus</Authors>
  <AssemblyName>ff-name</AssemblyName>
  <OutputType>Exe</OutputType>
 <TargetFramework>net8.0</TargetFramework>
 <ImplicitUsings>enable</ImplicitUsings>
  <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="10.0.10" />
    <PackageReference Include="System.CommandLine" Version="2.0.10" />
  </ItemGroup>

</Project>
